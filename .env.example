# Copy to .env and fill in — the real .env must NEVER be committed.
WEB_ORIGIN=http://your-domain.com        # public URL of the web app
SOCKET_URL=http://your-domain.com:3002   # public URL of the socket
TZ=America/Sao_Paulo
WEB_PORT=3003
SOCKET_PORT=3002
NGINX_PORT=80

# ── LDAP / Active Directory (optional — empty disables it) ──
LDAP_URL=                                # e.g. ldap://10.0.0.5:389
LDAP_DOMAIN=                             # e.g. company.local
LDAP_SEARCH_BASE=                        # e.g. DC=company,DC=local
LDAP_SERVICE_USER=                       # optional: read-only service account
LDAP_SERVICE_PASS=
