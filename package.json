{
  "name": "rahoot",
  "scripts": {
    "dev": "dotenv -e .env -- pnpm -r --parallel dev",
    "dev:web": "dotenv -e .env -- pnpm --filter web dev",
    "dev:socket": "dotenv -e .env -- pnpm --filter socket dev",
    "build": "pnpm -r run build",
    "start": "pnpm -r --parallel run start",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "lint": "pnpm -r run lint"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "supportedArchitectures": {
      "os": ["current", "linux"],
      "cpu": ["current", "x64"],
      "libc": ["current", "glibc", "musl"]
    },
    "overrides": {
      "ws@>=8.0.0 <8.21.0": ">=8.21.0",
      "socket.io-parser@<4.2.6": ">=4.2.6",
      "postcss@<8.5.10": ">=8.5.10",
      "dompurify@<3.4.9": ">=3.4.9"
    }
  }
}
